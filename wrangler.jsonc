{
  // Cloudflare Workers 정적 자산 배포 설정 (Next.js static export → out/)
  // 빌드: npm run build (out/ 생성) → 배포: npx wrangler deploy
  "name": "limk-peaceworks",
  "compatibility_date": "2025-06-01",
  "assets": {
    // 정적 결과물 폴더 (next.config.mjs 의 output:"export" 산출물)
    "directory": "./out",
    // trailingSlash:true 이므로 /path/ → /path/index.html 자동 처리
    "html_handling": "auto-trailing-slash",
    // 없는 경로는 Next export 의 404 페이지로 응답
    "not_found_handling": "404-page"
  }
}
